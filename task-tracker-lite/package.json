{
  "name": "task-tracker-lite",
  "version": "1.0.0",
  "description": "3-tier task tracker demo with vanilla web, Express API, and SQLite",
  "main": "api/server.js",
  "scripts": {
    "init-db": "node data/init-db.js",
    "dev": "nodemon api/server.js",
    "start": "node api/server.js",
    "test": "vitest run --globals",
    "test:watch": "vitest --globals",
    "test:ui-smoke": "vitest run --globals tests/ui/smoke.ui.test.js",
    "lint": "eslint .",
    "quality:check": "npm run lint && npm test && npm run test:ui-smoke"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^5.2.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "vitest": "^4.1.7"
  }
}
