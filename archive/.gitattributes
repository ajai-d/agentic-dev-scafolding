# ─────────────────────────────────────────────────────────────
# Default: auto-detect text files and normalize line endings to LF
# (works for Windows, macOS, and Linux contributors alike)
# ─────────────────────────────────────────────────────────────
* text=auto eol=lf

# ─────────────────────────────────────────────────────────────
# Explicit text files → LF
# ─────────────────────────────────────────────────────────────
*.md       text eol=lf
*.py       text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.json     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.sh       text eol=lf

# ─────────────────────────────────────────────────────────────
# Windows-only scripts → CRLF (required to execute on Windows)
# ─────────────────────────────────────────────────────────────
*.ps1      text eol=crlf
*.bat      text eol=crlf
*.cmd      text eol=crlf

# ─────────────────────────────────────────────────────────────
# Binary files → leave them alone
# ─────────────────────────────────────────────────────────────
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.otf      binary
