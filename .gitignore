# ─────────────────────────────────────────────────────────────
# Python  (based on github/gitignore/Python.gitignore)
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
env/
ENV/

# Pytest / coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/

# Type checkers
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# ─────────────────────────────────────────────────────────────
# Node  (based on github/gitignore/Node.gitignore)
# ─────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn/cache
.yarn/install-state.gz

# Build outputs
out/
.next/
.nuxt/
.turbo/
.parcel-cache/
.cache/

# ─────────────────────────────────────────────────────────────
# Playwright  (E2E test output)
# ─────────────────────────────────────────────────────────────
test-results/
playwright-report/
playwright/.cache/

# ─────────────────────────────────────────────────────────────
# Editors / IDEs
# ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json.example
!.vscode/extensions.json
.idea/
*.iml
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────────
# Operating systems
# ─────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# ─────────────────────────────────────────────────────────────
# Secrets / environment
# ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt

# ─────────────────────────────────────────────────────────────
# AI / agent scratch space
# ─────────────────────────────────────────────────────────────
scratch/
.aider*
.claude/
.cursor/
.copilot/

# ─────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────
*.log
logs/

# Local reference material (kept on disk, not committed)
GitHub Copilot Mastery*.html
references/
*.local.md
